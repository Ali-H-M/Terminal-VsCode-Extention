{
  "name": "terminal-profile-launcher",
  "displayName": "Terminal Profile Launcher",
  "description": "Launch multiple pre-configured terminal tabs with auto-run commands, split layouts, and saveable profiles",
  "version": "1.5.3",
  "publisher": "Ali-H-M",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ali-H-M/Terminal-VsCode-Extention.git"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "terminal",
    "launcher",
    "profile",
    "split",
    "automation",
    "workspace",
    "multi-terminal",
    "termprofile",
    "team"
  ],
  "sponsor": {
    "url": "https://github.com/sponsors/Ali-H-M"
  },
  "icon": "logo.ico",
  "activationEvents": [
    "workspaceContains:.termprofile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalLauncher.openSettings",
        "title": "Terminal Launcher: Open Settings"
      },
      {
        "command": "terminalLauncher.quickLaunch",
        "title": "Terminal Launcher: Quick Launch"
      },
      {
        "command": "terminalLauncher.launchProfile",
        "title": "Terminal Launcher: Launch Profile",
        "enablement": "false"
      },
      {
        "command": "terminalLauncher.exportProfiles",
        "title": "Terminal Launcher: Export Profiles"
      },
      {
        "command": "terminalLauncher.importProfiles",
        "title": "Terminal Launcher: Import Profiles"
      },
      {
        "command": "terminalLauncher.saveCurrentTerminals",
        "title": "Save Current Terminals as Profile",
        "icon": "$(save)"
      },
      {
        "command": "terminalLauncher.importFromTermprofile",
        "title": "Terminal Launcher: Import from .termprofile"
      },
      {
        "command": "terminalLauncher.createTermprofile",
        "title": "Terminal Launcher: Create .termprofile for Workspace"
      }
    ],
    "menus": {
      "terminal/title/context": [
        {
          "command": "terminalLauncher.saveCurrentTerminals",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Terminal Profile Launcher",
      "properties": {
        "terminalLauncher.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Send anonymous usage data to help improve the extension. Always respects VS Code's global `#telemetry.telemetryLevel#` setting — disabling global telemetry takes priority.",
          "tags": ["telemetry", "usesOnlineServices"]
        }
      }
    },
    "walkthroughs": [
      {
        "id": "terminal-profile-launcher.gettingStarted",
        "title": "Get started with Terminal Profile Launcher",
        "description": "Create and launch reusable terminal profiles — open multiple terminals with one click.",
        "steps": [
          {
            "id": "openSettings",
            "title": "Open the settings panel",
            "description": "Open the Terminal Launcher settings to manage your profiles.\n\n[Open Settings](command:terminalLauncher.openSettings)",
            "media": {
              "markdown": "walkthrough/step1.md"
            },
            "completionEvents": [
              "onCommand:terminalLauncher.openSettings"
            ]
          },
          {
            "id": "createProfile",
            "title": "Create your first profile",
            "description": "A profile is a saved set of terminals. Click **New Profile** in the settings panel, give it a name, and add your commands.\n\n[Open Settings](command:terminalLauncher.openSettings)",
            "media": {
              "markdown": "walkthrough/step2.md"
            },
            "completionEvents": [
              "onCommand:terminalLauncher.openSettings"
            ]
          },
          {
            "id": "quickLaunch",
            "title": "Launch with Quick Launch",
            "description": "Press the **Launch Terminal** button in the status bar, or run **Terminal Launcher: Quick Launch** from the Command Palette to open any profile instantly.\n\n[Quick Launch](command:terminalLauncher.quickLaunch)",
            "media": {
              "markdown": "walkthrough/step3.md"
            },
            "completionEvents": [
              "onCommand:terminalLauncher.quickLaunch"
            ]
          },
          {
            "id": "termprofile",
            "title": "Share profiles with your team",
            "description": "Create a **.termprofile** file in your repo root so teammates get the same terminal setup when they clone the project.\n\n[Create .termprofile](command:terminalLauncher.createTermprofile)",
            "media": {
              "markdown": "walkthrough/step4.md"
            },
            "completionEvents": [
              "onCommand:terminalLauncher.createTermprofile"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
